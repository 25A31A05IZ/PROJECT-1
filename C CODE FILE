GUESS THE NUMBER CHALLENGE
#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int number, guess, attempts = 0;
    int maxAttempts = 5;

    // Generate random number between 1 and 100
    srand(time(0));
    number = rand() % 100 + 1;

    printf("=== Guess The Number Game ===\n");
    printf("Guess a number between 1 and 100\n");
    printf("You have only %d attempts.\n\n", maxAttempts);

    while (attempts < maxAttempts) {
        printf("Enter your guess: ");
        scanf("%d", &guess);

        attempts++;

        if (guess == number) {
            printf("Congratulations! You guessed the number in %d attempts.\n", attempts);
            break;
        }
        else if (guess < number) {
            printf("Too low!\n");
        }
        else {
            printf("Too high!\n");
        }

        // Show remaining attempts
        printf("Attempts remaining: %d\n\n", maxAttempts - attempts);
    }

    // If user fails after 5 attempts
    if (guess != number) {
        printf("Game Over! You used all %d attempts.\n", maxAttempts);
        printf("The correct number was %d\n", number);
    }

    return 0;
}
